[Unit]
Description=Meiso Host Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/meiso_glass
ExecStart=/opt/meiso_glass/.venv/bin/meiso host --config /opt/meiso_glass/configs/examples/host.generic.yaml
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
