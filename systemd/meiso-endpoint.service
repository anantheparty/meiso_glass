[Unit]
Description=Meiso Glass Endpoint Agent
After=network-online.target
Wants=network-online.target

[Service]
WorkingDirectory=/opt/meiso_glass
ExecStart=/opt/meiso_glass/.venv/bin/meiso-endpoint --config /opt/meiso_glass/configs/examples/endpoint.generic.yaml
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
