{
  "name": "meiso-glass-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev docs --host 127.0.0.1",
    "docs:ensure": "bash scripts/docs_dev_ensure.sh",
    "docs:watch": "bash scripts/docs_dev_watch.sh",
    "docs:stop": "bash scripts/docs_dev_stop.sh",
    "docs:check-sidebar": "node scripts/check_docs_sidebar.mjs",
    "docs:build": "npm run docs:check-sidebar && vitepress build docs",
    "docs:preview": "vitepress preview docs --host 127.0.0.1"
  },
  "devDependencies": {
    "debug": "^4.4.3",
    "mermaid": "^11.15.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
